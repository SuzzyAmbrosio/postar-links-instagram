generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String            @id @default(cuid())
  name             String?
  email            String?           @unique
  emailVerified    DateTime?
  image            String?
  password         String?
  plan             String            @default("FREE")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  instagramConfigs InstagramConfig[]
  links            Link[] // ADICIONA ESSA LINHA
  settings         Settings?
  groups Group[]
  accounts          Account[]
  sessions          Session[]
  instagramAccounts InstagramAccount[]
  channelConfigs    ChannelConfig[]
  postLogs          PostLog[]
  telegramChannels TelegramChannel[]
  whatsappGroups   WhatsappGroup[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model InstagramAccount {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  instagramUserId String  @unique
  username        String
  accountId       String
  accessToken     String  @db.Text
  profilePicture  String?
  followersCount  Int     @default(0)
  isActive        Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  config         InstagramConfig?
  posts          InstagramPost[]
  channelConfigs ChannelConfig[] // ADICIONADO: relação reversa

  @@index([userId])
}

model InstagramConfig {
  id        String           @id @default(cuid())
  accountId String           @unique
  userId    String // ADICIONA ESSA LINHA
  account   InstagramAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade) // ADICIONA ESSA LINHA

  postInterval    Int?
  hashtagsDefault String   @default("#ofertas #promocao")
  linkInBio       String   @default("")
  templateId      String   @default("default")
  showPrice       Boolean  @default(true)
  showDiscount    Boolean  @default(true)
  autoPublish     Boolean  @default(true)
  publishStories  Boolean  @default(false)
  scheduleEnabled Boolean  @default(false)
  scheduleTimes   String[] @default([])

  shopeeId       String @default("")
  amazonId       String @default("")
  aliexpressId   String @default("")
  mercadoLivreId String @default("")
  sheinId        String @default("")

  productLink    String  @default("")
  keepLinkInPost Boolean @default(true)
  header         String  @default("")
  footer         String  @default("")
  precoOriginal  String  @default("")
  precoAtual     String  @default("")
  sufixoPreco    String  @default("")
  precoParcelado String  @default("")
  descricao      String  @default("")
  corTitulo      String  @default("#000000")
  corPreco       String  @default("#FFFFFF")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId]) // ADICIONA ESSE INDEX
}

model InstagramPost {
  id        String           @id @default(cuid())
  accountId String
  account   InstagramAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  instagramMediaId String?
  caption          String  @db.Text
  imageUrl         String?
  productUrl       String?
  status           String  @default("draft") // draft, scheduled, published, failed

  scheduledFor DateTime?
  publishedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountId])
  @@index([status])
}

model ChannelConfig {
  id                 String @id @default(cuid())
  userId             String
  instagramAccountId String @unique

  // Configurações de post
  isActive   Boolean @default(true)
  postInLoop Boolean @default(false)
  interval   Int?
  random     Boolean @default(false)
  horaInicio String?
  horaFim    String?
  idioma     String?
  moeda      String?
  pais       String?

  // Conteúdo do post
  productLink     String?
  keepLinkInPost  Boolean @default(true)
  header          String?
  footer          String?
  shopeeVideoLink String?
  useShopeeVideo  Boolean @default(false)
  precoOriginal   String?
  precoAtual      String?
  sufixoPreco     String?
  precoParcelado  String?
  descricao       String?
  agendamento     String?

  // Template
  corTitulo String?
  corPreco  String?
  templateImageUrl String?
  templateImageName String?
  templateSource String? @default("local")

  // Cupom
  tipoCupom     String?
  valorDesconto String?
  valorMinimo   String?
  valorMaximo   String?
  codigoCupom   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  instagramAccount InstagramAccount @relation(fields: [instagramAccountId], references: [id], onDelete: Cascade)

  postAuto Boolean @default(false)
  desativarComentario Boolean @default(false)
  agendamentoAtivo Boolean @default(false)

  storyTemplateUrl String?

  textoRespostaStory String?
  textoBotaoLink String?

  diasSelecionados String[] @default([])
  horariosSelecionados Int[] @default([])

  @@index([userId])
  @@map("channel_configs")
}

model PostLog {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  status  String // success | error | skipped
  detail  String? // Mensagem do log
  postUrl String? // URL do post criado

  instagramAccountId String?
  instagramUsername  String?
  productLink        String?
  productTitle       String?
  groupId        String?
  groupName      String?
  linkId         String?
  linkTitle      String?
  telegramChatId String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("post_logs")
}

model Link {
  id        String   @id @default(cuid())
  url       String
  title     String?
  shortCode String   @unique
  clicks    Int      @default(0)

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  groupId   String?
  group     Group?   @relation(fields: [groupId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([groupId])
}

model Settings {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  plan          String  @default("FREE")
  notifications Boolean @default(true)
  theme         String  @default("light")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  telegramBotToken        String?
  telegramChatId          String?
  telegramParseMode       String?
  telegramDisablePreview  Boolean @default(false)
  telegramDefaultMessage  String?
  telegramSignature       String?
  telegramConnected Boolean @default(false)

  whatsappInstanceId String?
  whatsappToken      String?
  whatsappGroupId    String?
  whatsappConnected         Boolean @default(false)
  telegramPinAfterSend      Boolean @default(false)

  whatsappGroupName         String?
  whatsappInviteLink        String?
  whatsappDefaultMessage    String?
  whatsappFooterCta         String?
  whatsappIncludeInviteLink Boolean @default(false)
  whatsappShortenText       Boolean @default(false)

  @@map("settings")
}

model TelegramChannel {
  id        String   @id @default(cuid())
  userId    String
  name      String
  chatId    String
  avatar    String?
  interval  Int?
  random    Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("telegram_channels")
}

model WhatsappGroup {
  id        String   @id @default(cuid())
  userId    String
  name      String
  groupId   String
  avatar    String?
  interval  Int?
  random    Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("whatsapp_groups")
}

model Group {
  id              String   @id @default(cuid())
  userId          String
  name            String
  internalCode    String?  @unique
  postAuto        Boolean  @default(false)
  isActive        Boolean  @default(true)
  intervalMinutes Int      @default(60)
  lastcreatedAt   DateTime?

  telegramToken  String?
  telegramChatId String?

  selectionMode  String?
  randomMode     Boolean @default(false)

  postTitle      String?
  postPriceLabel String?
  postCta        String?
  whatsappMessage  String?
  shopeeAffiliateId String?
  shopeeSubId       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  links Link[]

  @@index([userId])
  @@map("groups")
}